# Exemple de variables pour un futur build (Webpack/Vite) injectant la config Firebase.
# Projet actuel : configuration côté client via window.__FIREBASE_CONFIG__ (voir commentaire dans admin.html).

# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Après migration Firestore, définir aussi dans le HTML ou bundle :
# window.__APP_DATA_PROVIDER__ = 'firebase';

# Contact forms (Vercel serverless -> Google Apps Script)
CONTACT_GAS_URL_AUTHOR=
CONTACT_GAS_URL_PUBLISHER=

# Firebase auth verification for serverless routes
FIREBASE_WEB_API_KEY=
FIREBASE_ADMIN_UIDS=

# Cloudinary (server-side only for signed uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
